# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=False
ALLOWED_HOSTS=abby-api.bos.lol,localhost,127.0.0.1

# CORS — frontend origins allowed to call the API
CORS_ALLOWED_ORIGINS=https://abby.bos.lol,http://localhost:5173,http://localhost:3000

# Postgres (consumed by db service in docker-compose.yml)
POSTGRES_DB=summerforge
POSTGRES_USER=summerforge
POSTGRES_PASSWORD=change-me

# Database URL (consumed by Django)
DATABASE_URL=postgres://summerforge:change-me@db:5432/summerforge

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1

# Seed data passwords
PARENT_PASSWORD=summerforge2025
CHILD_PASSWORD=summerforge2025

# AI Suggestions (optional — falls back to curated suggestions if not set)
ANTHROPIC_API_KEY=
