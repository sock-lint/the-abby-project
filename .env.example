# ──────────────────────────────────────────────────────────────────────────
# Django
# ──────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
DEBUG=False

# Django + the React bundle are served from a single origin, so this only
# needs to list the public frontend hostname (plus any dev/preview fallbacks).
ALLOWED_HOSTS=abby.bos.lol,.sslip.io,localhost,127.0.0.1

# Origins trusted for CSRF-protected (unsafe) requests. Must include the
# public scheme + host of the site when deployed behind a reverse proxy.
CSRF_TRUSTED_ORIGINS=https://abby.bos.lol

# ──────────────────────────────────────────────────────────────────────────
# CORS — only used by the local Vite dev server
# ──────────────────────────────────────────────────────────────────────────
# Production builds serve the React bundle from Django itself (same origin),
# so no cross-origin requests happen in production. These defaults cover
# `cd frontend && npm run dev` (which runs on :3000 / :5173 and proxies /api
# to Django on :8000).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# Postgres (consumed by the db service in docker-compose.yml)
# ──────────────────────────────────────────────────────────────────────────
POSTGRES_DB=summerforge
POSTGRES_USER=summerforge
POSTGRES_PASSWORD=change-me

# Database URL consumed by Django via dj-database-url.
# IMPORTANT: URL-encode any special chars in the password.
#   @ -> %40   # -> %23   / -> %2F   : -> %3A   & -> %26
DATABASE_URL=postgres://summerforge:change-me@db:5432/summerforge

# ──────────────────────────────────────────────────────────────────────────
# Redis / Celery
# ──────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ──────────────────────────────────────────────────────────────────────────
# Seed data (used by `python manage.py seed_data`)
# ──────────────────────────────────────────────────────────────────────────
PARENT_PASSWORD=summerforge2025
CHILD_PASSWORD=summerforge2025

# ──────────────────────────────────────────────────────────────────────────
# MCP server — DNS rebinding protection
# ──────────────────────────────────────────────────────────────────────────
# The MCP SDK's TransportSecurityMiddleware validates the Host header
# against an allow-list and returns HTTP 421 on mismatch. If unset, the
# allow-list is derived from ALLOWED_HOSTS + CSRF_TRUSTED_ORIGINS plus
# loopback defaults — so the public hostname already listed in
# ALLOWED_HOSTS (e.g. abby.bos.lol) "just works". Override here only if
# the MCP server sits behind a different hostname than the main app, or
# set either value to "*" to disable DNS rebinding protection entirely.
# MCP_ALLOWED_HOSTS=abby.bos.lol,abby.bos.lol:*
# MCP_ALLOWED_ORIGINS=https://abby.bos.lol

# Public URL at which the MCP server is reachable. Advertised to clients.
# MCP_PUBLIC_BASE_URL=https://abby.bos.lol/mcp

# ──────────────────────────────────────────────────────────────────────────
# Optional — AI suggestions. If blank, the app falls back to curated lists.
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Optional — Google OAuth + Calendar. If blank, the Google sign-in button
# won't appear and calendar sync is disabled.
# Create credentials at https://console.cloud.google.com/apis/credentials
# ──────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ──────────────────────────────────────────────────────────────────────────
# Sentry error tracking (optional — if blank, error tracking is disabled)
# ──────────────────────────────────────────────────────────────────────────
# DSN from your Sentry instance (Settings → Projects → Client Keys)
SENTRY_DSN=
# Environment tag shown in Sentry (auto-derived from DEBUG if unset)
SENTRY_ENVIRONMENT=production
# Fraction of requests to trace for performance monitoring (0.0 – 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.2
# Git SHA or version tag for release tracking (auto-set by CI)
SENTRY_RELEASE=

# Frontend Sentry — Vite env vars must be prefixed with VITE_
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
# Release tag baked into frontend bundle (auto-set by CI build arg)
VITE_SENTRY_RELEASE=

# ──────────────────────────────────────────────────────────────────────────
# Sentry release automation (CI-only — NOT needed in runtime .env)
# ──────────────────────────────────────────────────────────────────────────
# These are passed as Docker build args and GitHub Actions env vars.
# The Vite plugin uploads source maps during the frontend build stage.
# Store these as GitHub repository secrets, not in .env files.
# SENTRY_AUTH_TOKEN=     # API token from logs.neato.digital
# SENTRY_ORG=            # Organization slug in Sentry
# SENTRY_PROJECT=        # Frontend project slug in Sentry
