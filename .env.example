# ──────────────────────────────────────────────────────────────────────────
# Django
# ──────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
DEBUG=False

# Hosts Django will accept requests for. In the default same-origin setup the
# nginx container proxies /api to Django, so Django sees the *frontend* host
# via X-Forwarded-Host — include it here. Also list any sslip.io / localhost
# fallbacks you use in dev or Coolify previews.
ALLOWED_HOSTS=abby.bos.lol,.sslip.io,localhost,127.0.0.1

# Origins trusted for CSRF-protected (unsafe) requests. Must include the
# public scheme + host of the frontend when deployed behind a reverse proxy.
CSRF_TRUSTED_ORIGINS=https://abby.bos.lol

# ──────────────────────────────────────────────────────────────────────────
# CORS — origins allowed to call the API from the browser
# ──────────────────────────────────────────────────────────────────────────
# Auth is token-based (DRF TokenAuthentication), so CORS credentials are
# not required. In same-origin mode these are only needed for the local Vite
# dev server; a production build that proxies /api through nginx never makes
# a cross-origin request.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# Postgres (consumed by the db service in docker-compose.yml)
# ──────────────────────────────────────────────────────────────────────────
POSTGRES_DB=summerforge
POSTGRES_USER=summerforge
POSTGRES_PASSWORD=change-me

# Database URL consumed by Django via dj-database-url.
# IMPORTANT: URL-encode any special chars in the password.
#   @ -> %40   # -> %23   / -> %2F   : -> %3A   & -> %26
DATABASE_URL=postgres://summerforge:change-me@db:5432/summerforge

# ──────────────────────────────────────────────────────────────────────────
# Redis / Celery
# ──────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ──────────────────────────────────────────────────────────────────────────
# Frontend build-time config (Vite)
# ──────────────────────────────────────────────────────────────────────────
# Base URL the React bundle will call for API requests. Baked in at
# `npm run build` time via a Docker build-arg, so this must be set as a
# BUILD variable in Coolify (not just a runtime env var). No trailing slash.
#
# Leave blank (the default) for same-origin mode: the nginx container proxies
# /api/, /admin/, /static/, /media/, /health to the django service, so the
# bundle uses relative URLs and one public hostname serves everything. This
# avoids CORS, mixed-content, and Chrome Private Network Access issues when
# the site is reached from outside the LAN.
#
# Only set this if you deliberately want to host the API on a separate
# public domain — in which case also add it to ALLOWED_HOSTS,
# CSRF_TRUSTED_ORIGINS, and CORS_ALLOWED_ORIGINS above.
VITE_API_URL=

# ──────────────────────────────────────────────────────────────────────────
# Seed data (used by `python manage.py seed_data`)
# ──────────────────────────────────────────────────────────────────────────
PARENT_PASSWORD=summerforge2025
CHILD_PASSWORD=summerforge2025

# ──────────────────────────────────────────────────────────────────────────
# Optional — AI suggestions. If blank, the app falls back to curated lists.
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
