# ──────────────────────────────────────────────────────────────────────────
# Django
# ──────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
DEBUG=False

# Django + the React bundle are served from a single origin, so this only
# needs to list the public frontend hostname (plus any dev/preview fallbacks).
ALLOWED_HOSTS=abby.bos.lol,.sslip.io,localhost,127.0.0.1

# Origins trusted for CSRF-protected (unsafe) requests. Must include the
# public scheme + host of the site when deployed behind a reverse proxy.
CSRF_TRUSTED_ORIGINS=https://abby.bos.lol

# ──────────────────────────────────────────────────────────────────────────
# CORS — only used by the local Vite dev server
# ──────────────────────────────────────────────────────────────────────────
# Production builds serve the React bundle from Django itself (same origin),
# so no cross-origin requests happen in production. These defaults cover
# `cd frontend && npm run dev` (which runs on :3000 / :5173 and proxies /api
# to Django on :8000).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# Postgres (consumed by the db service in docker-compose.yml)
# ──────────────────────────────────────────────────────────────────────────
POSTGRES_DB=summerforge
POSTGRES_USER=summerforge
POSTGRES_PASSWORD=change-me

# Database URL consumed by Django via dj-database-url.
# IMPORTANT: URL-encode any special chars in the password.
#   @ -> %40   # -> %23   / -> %2F   : -> %3A   & -> %26
DATABASE_URL=postgres://summerforge:change-me@db:5432/summerforge

# ──────────────────────────────────────────────────────────────────────────
# Redis / Celery
# ──────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ──────────────────────────────────────────────────────────────────────────
# Seed data (used by `python manage.py seed_data`)
# ──────────────────────────────────────────────────────────────────────────
PARENT_PASSWORD=summerforge2025
CHILD_PASSWORD=summerforge2025

# ──────────────────────────────────────────────────────────────────────────
# Optional — AI suggestions. If blank, the app falls back to curated lists.
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
