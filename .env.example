# ──────────────────────────────────────────────────────────────────────────
# Django
# ──────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
DEBUG=False

# Hosts Django will accept requests for. Include your API domain and any
# sslip.io / localhost fallbacks you use in dev or Coolify previews.
ALLOWED_HOSTS=abby-api.bos.lol,.sslip.io,localhost,127.0.0.1

# ──────────────────────────────────────────────────────────────────────────
# CORS — origins allowed to call the API from the browser
# ──────────────────────────────────────────────────────────────────────────
# Auth is token-based (DRF TokenAuthentication), so CORS credentials are
# not required — the browser just needs to be allowed to fetch cross-origin.
CORS_ALLOWED_ORIGINS=https://abby.bos.lol,http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# Postgres (consumed by the db service in docker-compose.yml)
# ──────────────────────────────────────────────────────────────────────────
POSTGRES_DB=summerforge
POSTGRES_USER=summerforge
POSTGRES_PASSWORD=change-me

# Database URL consumed by Django via dj-database-url.
# IMPORTANT: URL-encode any special chars in the password.
#   @ -> %40   # -> %23   / -> %2F   : -> %3A   & -> %26
DATABASE_URL=postgres://summerforge:change-me@db:5432/summerforge

# ──────────────────────────────────────────────────────────────────────────
# Redis / Celery
# ──────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ──────────────────────────────────────────────────────────────────────────
# Frontend build-time config (Vite)
# ──────────────────────────────────────────────────────────────────────────
# Base URL the React bundle will call for API requests. Baked in at
# `npm run build` time via a Docker build-arg, so this must be set as a
# BUILD variable in Coolify (not just a runtime env var). No trailing slash.
VITE_API_URL=https://abby-api.bos.lol

# ──────────────────────────────────────────────────────────────────────────
# Seed data (used by `python manage.py seed_data`)
# ──────────────────────────────────────────────────────────────────────────
PARENT_PASSWORD=summerforge2025
CHILD_PASSWORD=summerforge2025

# ──────────────────────────────────────────────────────────────────────────
# Optional — AI suggestions. If blank, the app falls back to curated lists.
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
